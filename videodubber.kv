<VideoListItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: 40
    canvas.before:
        Color:
            rgba: (0.2, 0.6, 0.8, 1) if self.selected else (0.9, 0.9, 0.9, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: root.video_name if root.video_name else '空'
        size_hint_x: 0.8
        halign: 'left'
        text_size: self.size
        valign: 'middle'
    Label:
        text: '选择' if not root.selected else '已选'
        size_hint_x: 0.2
        halign: 'center'
        valign: 'middle'
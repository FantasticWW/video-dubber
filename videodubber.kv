<VideoListItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: 50
    padding: 5, 2

    canvas.before:
        Color:
            rgba: (0.2, 0.6, 1.0, 1) if self.selected else (0.95, 0.95, 0.95, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'
        spacing: 5

        Label:
            text: root.video_name if root.video_name else 'Video'
            size_hint_x: 0.85
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            color: (0, 0, 0, 1)

        BoxLayout:
            size_hint_x: 0.15
            orientation: 'vertical'

            Button:
                text: 'Play'
                size_hint_y: None
                height: 40
                on_press: app.root.select_video(root.index)